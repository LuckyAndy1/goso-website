---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Section from '@components/ui/Section.astro';
import { getI18n } from '@/i18n';
import logisticsImg from '@assets/photo-1578575437130-527eed3abbec.jpg';
import warehouseImg from '@assets/photo-1518770660439-4636190af475.jpg';

const content = getI18n(Astro.url.pathname);
const page = content.pages.logistics;
---

<BaseLayout title={`${page.metaTitle}｜${content.company.name}`} description={page.metaDescription}>
  <PageHero eyebrow={page.heroEyebrow} title={page.heroTitle} description={page.heroDescription} image={logisticsImg} imageAlt={page.imageAlt} />
  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:items-center">
      <div class="min-w-0">
        <h2 class="text-3xl font-semibold text-slate-950">{page.sectionTitle}</h2>
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {content.warehouseCapabilities.map((item) => (
            <div class="rounded-md border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700">{item}</div>
          ))}
        </div>
      </div>
      <div class="min-w-0">
        <Image src={warehouseImg} alt={page.warehouseImageAlt} class="aspect-4/3 w-full rounded-lg object-cover shadow-sm" width={1200} height={800} />
      </div>
    </div>
  </Section>
  <Section background="gradient">
    <div class="mb-10 max-w-3xl">
      <p class="text-sm font-semibold text-[#9b7836]">{page.flowEyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold text-slate-950">{page.flowTitle}</h2>
    </div>
    <div class="grid gap-4 md:grid-cols-3 xl:grid-cols-6">
      {page.flow.map(([title, text], index) => (
        <div class="rounded-lg bg-white p-5 shadow-sm">
          <div class="text-sm font-semibold text-[#9b7836]">{String(index + 1).padStart(2, '0')}</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-950">{title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{text}</p>
        </div>
      ))}
    </div>
  </Section>
</BaseLayout>
