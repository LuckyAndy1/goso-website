---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Section from '@components/ui/Section.astro';
import { Icon } from 'astro-iconset/components';
import { getI18n } from '@/i18n';
import fulfillmentImg from '@assets/photo-1586528116311-ad8dd3c8310d.jpg';

const content = getI18n(Astro.url.pathname);
const page = content.pages.fulfillment;
---

<BaseLayout title={`${page.metaTitle}｜${content.company.name}`} description={page.metaDescription}>
  <PageHero eyebrow={page.heroEyebrow} title={page.heroTitle} description={page.heroDescription} image={fulfillmentImg} imageAlt={page.imageAlt} />
  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-[#9b7836]">{page.sectionEyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold text-slate-950 md:text-4xl">{page.sectionTitle}</h2>
        <p class="mt-5 leading-8 text-slate-600">{page.sectionDescription}</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {page.capabilities.map(([title, text]) => (
          <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-[#eef5f1] text-[#0f4a3c]">
                <Icon name="lucide:check" class="h-4 w-4" />
              </span>
              <h3 class="font-semibold text-slate-950">{title}</h3>
            </div>
            <p class="mt-3 text-sm leading-7 text-slate-600">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>
  <Section background="gradient">
    <div class="mb-10 max-w-3xl">
      <p class="text-sm font-semibold text-[#9b7836]">{page.flowEyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold text-slate-950">{page.flowTitle}</h2>
    </div>
    <div class="grid gap-4 md:grid-cols-3 xl:grid-cols-6">
      {page.flow.map(([title, text], index) => (
        <div class="rounded-lg bg-white p-5 shadow-sm">
          <div class="text-sm font-semibold text-[#9b7836]">{String(index + 1).padStart(2, '0')}</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-950">{title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{text}</p>
        </div>
      ))}
    </div>
  </Section>
</BaseLayout>
