---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Section from '@components/ui/Section.astro';
import { Icon } from 'astro-iconset/components';
import { getI18n, localizePath } from '@/i18n';
import businessImg from '@assets/photo-1486406146926-c627a92ad1ab.jpg';

const content = getI18n(Astro.url.pathname);
const page = content.pages.business;
---

<BaseLayout title={`${page.metaTitle}｜${content.company.name}`} description={page.metaDescription}>
  <PageHero eyebrow={page.heroEyebrow} title={page.heroTitle} description={page.heroDescription} image={businessImg} imageAlt={page.imageAlt} />
  <Section>
    <div class="grid gap-8 lg:grid-cols-[minmax(260px,0.72fr)_minmax(0,1.28fr)] lg:gap-16">
      <div class="self-start">
        <p class="text-sm font-semibold text-[#9b7836]">{page.servicesEyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold text-slate-950 md:text-4xl">{page.servicesTitle}</h2>
        <p class="mt-5 leading-8 text-slate-600">{page.servicesDescription}</p>
        <nav class="mt-8 border-y border-slate-300" aria-label={page.servicesEyebrow}>
          {content.services.map((service, index) => (
            <a href={`#service-${index + 1}`} class="group flex items-center gap-4 border-b border-slate-200 py-4 last:border-b-0">
              <span class="text-xs font-semibold text-[#9b7836]">0{index + 1}</span>
              <span class="min-w-0 flex-1 text-sm font-semibold text-slate-800 transition-colors group-hover:text-[#0f4a3c]">{service.title}</span>
              <Icon name="lucide:arrow-down-right" class="h-4 w-4 shrink-0 text-slate-400 transition-colors group-hover:text-[#0f4a3c]" />
            </a>
          ))}
        </nav>
        <div class="mt-10 border-t border-slate-300 pt-8">
          <p class="text-sm font-semibold text-[#9b7836]">{page.workflowEyebrow}</p>
          <h3 class="mt-3 text-2xl font-semibold leading-8 text-slate-950">{page.workflowTitle}</h3>
          <ol class="mt-7 border-l border-slate-300 pl-6">
            {page.workflow.map(([step, title, text]) => (
              <li class="relative pb-7 last:pb-0">
                <span class="absolute -left-[29px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-white bg-[#0f4a3c] ring-1 ring-[#0f4a3c]"></span>
                <div class="flex items-baseline gap-3">
                  <span class="text-xs font-semibold text-[#9b7836]">{step}</span>
                  <h4 class="text-base font-semibold text-slate-950">{title}</h4>
                </div>
                <p class="mt-2 text-sm leading-7 text-slate-600">{text}</p>
              </li>
            ))}
          </ol>
        </div>
        <a href={localizePath('/contact', content.locale)} class="mt-7 inline-flex items-center gap-2 rounded-md border border-[#0f4a3c] px-5 py-3 text-sm font-semibold text-[#0f4a3c] transition-colors hover:bg-[#0f4a3c] hover:text-white">
          {content.common.contactUs}
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
      </div>
      <div class="border-y border-slate-300">
        {page.serviceDetails.map(([description, outcome, points], index) => {
          const service = content.services[index];
          return (
          <article id={`service-${index + 1}`} class="grid scroll-mt-24 gap-5 border-b border-slate-200 py-8 last:border-b-0 sm:grid-cols-[56px_minmax(0,1fr)] lg:py-10">
            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-[#eef5f1] text-[#0f4a3c]">
              <Icon name={service.icon} class="h-6 w-6" />
            </div>
            <div class="min-w-0">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <p class="text-xs font-semibold text-[#9b7836]">0{index + 1}</p>
                  <h3 class="mt-2 text-2xl font-semibold text-slate-950">{service.title}</h3>
                </div>
                <a href={localizePath(service.href, content.locale)} class="inline-flex shrink-0 items-center gap-2 text-sm font-semibold text-[#0f4a3c] hover:text-[#9b7836]">
                  {page.serviceLink}
                  <Icon name="lucide:arrow-right" class="h-4 w-4" />
                </a>
              </div>
              <p class="mt-4 leading-8 text-slate-600">{description}</p>
              <div class="mt-5 grid gap-x-6 gap-y-2 sm:grid-cols-2">
                {points.map((point) => (
                  <div class="flex items-center gap-2 text-sm text-slate-700">
                    <Icon name="lucide:check" class="h-4 w-4 shrink-0 text-[#0f4a3c]" />
                    <span>{point}</span>
                  </div>
                ))}
              </div>
              <div class="mt-6 border-l-2 border-[#d6b978] pl-4">
                <p class="text-xs font-semibold text-[#9b7836]">{page.outcomeLabel}</p>
                <p class="mt-2 text-sm leading-7 text-slate-700">{outcome}</p>
              </div>
            </div>
          </article>
          );
        })}
      </div>
    </div>
  </Section>
</BaseLayout>
