---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import { getI18n, localizePath } from '@/i18n';
import { Icon } from 'astro-iconset/components';
import heroImg from '@assets/photo-1566576721346-d4a3b4eaeb55.jpg';
import officeImg from '@assets/photo-1558494949-ef010cbdcc31.jpg';
import warehouseImg from '@assets/photo-1601584115197-04ecc0da31d7.jpg';

const content = getI18n(Astro.url.pathname);
const toHref = (href: string) => localizePath(href, content.locale);
---

<BaseLayout title={content.site.title} description={content.site.description}>
  <section class="relative overflow-hidden bg-[#10242b]">
    <div class="absolute inset-0">
      <Image src={heroImg} alt={content.home.warehouseTitle} class="h-full w-full object-cover opacity-40" width={2070} height={1380} />
      <div class="absolute inset-0 bg-[#10242b]/70"></div>
    </div>
    <div class="relative mx-auto grid min-h-[680px] max-w-7xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
      <div>
        <p class="mb-5 text-sm font-semibold text-[#d6b978]">{content.home.hero.eyebrow}</p>
        <h1 class="max-w-4xl text-4xl font-semibold leading-tight tracking-normal text-white md:text-6xl">
          {content.home.hero.title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-200">{content.home.hero.subtitle}</p>
        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a href={toHref(content.home.hero.primaryCta.href)} class="inline-flex items-center justify-center rounded-md bg-[#d6b978] px-6 py-3 text-sm font-semibold text-[#10242b] transition hover:bg-[#e2c989]">
            {content.home.hero.primaryCta.label}
          </a>
          <a href={toHref(content.home.hero.secondaryCta.href)} class="inline-flex items-center justify-center rounded-md border border-white/40 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
            {content.home.hero.secondaryCta.label}
          </a>
        </div>
      </div>
      <div class="rounded-lg border border-white/15 bg-white/10 p-5 backdrop-blur">
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
          {content.stats.map((stat) => (
            <div class="flex min-w-0 items-center justify-between gap-5 rounded-md bg-white/90 px-5 py-4">
              <div class="text-3xl font-semibold text-[#123c4a]">{stat.value}</div>
              <div class="whitespace-nowrap text-sm text-slate-600">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center">
      <div class="min-w-0">
        <Image src={officeImg} alt={content.pages.about.imageAlt} class="aspect-4/3 w-full rounded-lg object-cover shadow-sm" width={1200} height={800} />
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-[#9b7836]">{content.home.intro.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-normal text-slate-950 md:text-4xl">{content.home.intro.title}</h2>
        <p class="mt-5 text-base leading-8 text-slate-600">{content.home.intro.body}</p>
        <p class="mt-5 text-base leading-8 text-slate-600">{content.home.intro.extra}</p>
      </div>
    </div>
  </Section>

  <Section background="gray">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold text-[#9b7836]">{content.home.servicesEyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-normal text-slate-950 md:text-4xl">{content.home.servicesTitle}</h2>
      </div>
      <a href={toHref('/business')} class="text-sm font-semibold text-[#0f4a3c] hover:text-[#9b7836]">{content.home.servicesLink}</a>
    </div>
    <ServiceGrid />
  </Section>

  <Section>
    <div class="grid gap-6 lg:grid-cols-4">
      {content.home.advantages.map((item) => (
        <div class="rounded-lg border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold text-slate-950">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section background="gradient">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:items-center">
      <div class="min-w-0">
        <p class="text-sm font-semibold text-[#9b7836]">{content.home.warehouseEyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-normal text-slate-950 md:text-4xl">{content.home.warehouseTitle}</h2>
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {content.warehouseCapabilities.map((item) => (
            <div class="flex items-center gap-3 rounded-md bg-white px-4 py-3 text-sm text-slate-700 shadow-sm">
              <Icon name="lucide:check" class="h-4 w-4 text-[#0f4a3c]" />
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="min-w-0">
        <Image src={warehouseImg} alt={content.pages.logistics.imageAlt} class="aspect-4/3 w-full rounded-lg object-cover shadow-sm" width={1200} height={800} />
      </div>
    </div>
  </Section>

  <Section>
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold text-[#9b7836]">{content.home.newsEyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-normal text-slate-950 md:text-4xl">{content.home.newsTitle}</h2>
      </div>
      <a href={toHref('/news')} class="text-sm font-semibold text-[#0f4a3c] hover:text-[#9b7836]">{content.home.newsLink}</a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {content.home.news.map((item) => (
        <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between text-sm text-slate-500">
            <span>{item.category}</span>
            <time>{item.date}</time>
          </div>
          <h3 class="mt-4 text-lg font-semibold leading-7 text-slate-950">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.excerpt}</p>
        </article>
      ))}
    </div>
  </Section>

  <section class="bg-[#10242b]">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-14 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div class="rounded-lg bg-white p-8">
        <h2 class="text-2xl font-semibold text-slate-950">{content.home.recruitCard.title}</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">{content.home.recruitCard.text}</p>
        <a href={toHref('/recruit')} class="mt-6 inline-flex text-sm font-semibold text-[#0f4a3c]">{content.home.recruitCard.link}</a>
      </div>
      <div class="rounded-lg bg-[#d6b978] p-8 text-[#10242b]">
        <h2 class="text-2xl font-semibold">{content.home.contactCard.title}</h2>
        <p class="mt-3 text-sm leading-7">{content.home.contactCard.text}</p>
        <a href={toHref('/contact')} class="mt-6 inline-flex rounded-md bg-[#10242b] px-5 py-3 text-sm font-semibold text-white">{content.home.contactCard.link}</a>
      </div>
    </div>
  </section>
</BaseLayout>
