---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Section from '@components/ui/Section.astro';
import { Icon } from 'astro-iconset/components';
import { getI18n } from '@/i18n';
import ecImg from '@assets/photo-1563013544-824ae1b704d3.jpg';
import ecDashboardImg from '@assets/photo-1460925895917-afdab827c52f.jpg';

const content = getI18n(Astro.url.pathname);
const page = content.pages.ecService;
const rakutenStoreUrl = 'https://www.rakuten.co.jp/lican/';
---

<BaseLayout title={`${page.metaTitle}｜${content.company.name}`} description={page.metaDescription}>
  <PageHero eyebrow={page.heroEyebrow} title={page.heroTitle} description={page.heroDescription} image={ecImg} imageAlt={page.imageAlt} />
  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
      <div class="rounded-lg bg-[#10242b] p-6 text-white">
        <Image src={ecDashboardImg} alt={page.dashboardImageAlt} class="aspect-4/3 w-full rounded-md object-cover" width={1200} height={800} />
        <div class="mt-6 grid grid-cols-2 gap-3">
          {page.dashboards.map(([label, value]) => (
            <div class="rounded-md bg-white/10 p-4">
              <div class="text-sm text-slate-300">{label}</div>
              <div class="mt-2 font-semibold text-[#d6b978]">{value}</div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <p class="text-sm font-semibold text-[#9b7836]">{page.sectionEyebrow}</p>
        <h2 class="mt-3 text-3xl font-semibold text-slate-950">{page.sectionTitle}</h2>
        <div class="mt-8 grid gap-4">
          {page.modules.map(([title, text]) => (
            <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
              <h3 class="font-semibold text-slate-950">{title}</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">{text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>
  <Section background="gradient">
    <div class="overflow-hidden rounded-lg bg-[#10242b] px-6 py-8 text-white shadow-sm sm:px-8 lg:grid lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-12 lg:px-12 lg:py-10">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 text-[#d6b978]">
          <span class="flex h-10 w-10 items-center justify-center rounded-md bg-white/10">
            <Icon name="lucide:shopping-bag" class="h-5 w-5" />
          </span>
          <p class="text-sm font-semibold">{page.storeEyebrow}</p>
        </div>
        <h2 class="mt-5 text-3xl font-semibold">{page.storeTitle}</h2>
        <p class="mt-4 leading-8 text-slate-200">{page.storeDescription}</p>
      </div>
      <a
        href={rakutenStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-md bg-[#d6b978] px-6 py-3.5 text-sm font-semibold text-[#10242b] transition-colors hover:bg-[#e2c989] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d6b978] sm:w-auto lg:mt-0"
      >
        {page.storeButton}
        <Icon name="lucide:external-link" class="h-4 w-4" />
      </a>
    </div>
  </Section>
  <Section background="gray">
    <div class="grid gap-5 md:grid-cols-3">
      {page.scenarios.map((item) => (
        <div class="rounded-lg border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold text-slate-950">{item}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{page.scenarioText}</p>
        </div>
      ))}
    </div>
  </Section>
</BaseLayout>
