---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { eyebrow, title, description, image, imageAlt = title } = Astro.props;
---

<section class="bg-[#10242b]">
  <div class={`mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:px-8 lg:py-20 ${image ? 'lg:grid-cols-[0.95fr_1.05fr] lg:items-center' : ''}`}>
    <div class="max-w-3xl">
      {eyebrow && <p class="mb-4 text-sm font-semibold text-[#d6b978]">{eyebrow}</p>}
      <h1 class="text-4xl font-semibold leading-tight tracking-normal text-white md:text-5xl">{title}</h1>
      <p class="mt-6 text-lg leading-8 text-slate-200">{description}</p>
    </div>

    {image && (
      <div class="relative overflow-hidden rounded-lg border border-white/15 bg-white/10 p-3 shadow-lg">
        <Image
          src={image}
          alt={imageAlt}
          class="aspect-[16/10] w-full rounded-md object-cover"
          width={1200}
          height={750}
        />
        <div class="absolute inset-3 rounded-md bg-linear-to-t from-[#10242b]/35 to-transparent"></div>
      </div>
    )}
  </div>
</section>
