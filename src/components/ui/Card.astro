---
interface Props {
  class?: string;
  hover?: boolean;
  style?: string;
}

const { 
  class: className = '',
  hover = false,
  style
} = Astro.props;

const baseStyles = 'rounded-lg border border-slate-200 bg-white p-6 shadow-sm';
const hoverStyles = hover ? 'transition-all duration-300 hover:border-[#c9a45c] hover:shadow-md' : '';
const classes = `${baseStyles} ${hoverStyles} ${className}`;
---

<div class={classes} style={style}>
  <slot />
</div>
