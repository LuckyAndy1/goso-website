---
import { Icon } from 'astro-iconset/components';
import { getI18n, localizePath } from '@/i18n';

interface Props {
  currentPathname?: string;
}

const { currentPathname = Astro.url.pathname } = Astro.props;
const content = getI18n(currentPathname);
---

<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
  {content.services.map((service) => (
    <a href={localizePath(service.href, content.locale)} class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition hover:border-[#c9a45c] hover:shadow-md">
      <span class="flex h-11 w-11 items-center justify-center rounded-md bg-[#eef5f1] text-[#0f4a3c]">
        <Icon name={service.icon} class="h-5 w-5" />
      </span>
      <h3 class="mt-5 text-xl font-semibold text-slate-950">{service.title}</h3>
      <p class="mt-3 text-sm leading-7 text-slate-600">{service.summary}</p>
      <span class="mt-5 inline-flex text-sm font-semibold text-[#0f4a3c] group-hover:text-[#9b7836]">{content.common.learnMore}</span>
    </a>
  ))}
</div>
